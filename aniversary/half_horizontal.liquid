{% render "anniversary_styles" %}
<div class="view view--half_horizontal aniv-view">
  <div class="layout aniv-layout aniv-layout--center gap--small">
    {% render "anniversary_screen", special_dates: trmnl.plugin_settings.custom_fields_values.special_dates, months_back: trmnl.plugin_settings.custom_fields_values.months_back, months_forward: trmnl.plugin_settings.custom_fields_values.months_forward, trmnl: trmnl, mode: "half_horizontal", compact: true %}
  </div>
  <div class="title_bar">
    <img class="image" src="data:image/svg+xml;base64," />
    <span class="title">Anniversary Timeline</span>
    <span class="instance">{{ trmnl.plugin_settings.instance_name }}</span>
  </div>
</div>
