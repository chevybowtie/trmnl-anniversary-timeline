{% comment %}
  Shared markup for the Anniversary Timeline plugin.
  Paste this entire file into the "Shared" tab of the Markup Editor.
  It defines the reusable `timeline_dot` / `month_tick` / `anniversary_styles`
  templates plus the main `anniversary_screen` template that every layout
  (full, half_horizontal, half_vertical, quadrant) renders with a different
  `mode`.

  Data format for the `special_dates` custom field (one entry per line):
    YYYY-MM-DD|Label|once      -> a one-time event, never repeats
    YYYY-MM-DD|Label|yearly    -> repeats every year, "N yrs" badge shown
    MM-DD|Label|yearly         -> repeats every year, no start year known,
                                  so no "N yrs" badge is shown

  Example:
    2026-08-20|Wedding Anniversary|yearly
    1990-03-02|Mom's Birthday|yearly
    2026-12-25|Office Holiday Party|once
{% endcomment %}

{% template anniversary_styles %}
  <style>
    {% comment %}
      No CSS opacity anywhere here -- it's explicitly flagged by TRMNL's
      plugin checker and renders unreliably on 1-bit e-ink. The Framework's
      text--gray-NN classes were tried as the suggested replacement for
      de-emphasized text, but on-device (confirmed on a real TRMNL) the
      dither pattern they use breaks small text (under ~16px) into
      illegible dots rather than a clean gray -- fine on large text, not on
      captions/labels this size. So small secondary text here is just plain
      solid black, differentiated from primary text by size/weight alone.
    {% endcomment %}

    .aniv-view { display: flex; flex-direction: column; height: 100%; }
    .aniv-layout { flex: 1; display: flex; flex-direction: column; min-height: 0; }
    .aniv-layout--center { justify-content: center; }

    .aniv-half { width: 100%; box-sizing: border-box; min-height: 0; display: flex; align-items: center; justify-content: center; }
    .aniv-half--start { align-items: flex-start; }
    .aniv-half--r40 { flex: 0 0 40%; }
    .aniv-half--r45 { flex: 0 0 45%; }
    .aniv-half--r50 { flex: 0 0 50%; }
    .aniv-half--r55 { flex: 0 0 55%; }
    .aniv-half--r60 { flex: 0 0 60%; }

    .aniv-date { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; width: 100%; }
    .aniv-date__weekday { font-size: 28px; letter-spacing: 2px; text-transform: uppercase; }
    .aniv-date__big { font-size: 110px; font-weight: 700; line-height: 1; margin: 4px 0; }
    .aniv-date__big--sm { font-size: 64px; }
    .aniv-date__big--xs { font-size: 40px; }
    .aniv-date__year { font-size: 24px; margin-top: 16px; }
    .aniv-date__next { display: block; font-size: 16px; margin-top: 10px; }
    .aniv-date--row { flex-direction: row; gap: 24px; }
    .aniv-date--row .aniv-date__weekday { font-size: 22px; }
    .aniv-date--quad { gap: 2px; }

    .aniv-timeline { position: relative; width: 100%; height: 100%; padding: 0 24px; box-sizing: border-box; }
    .timeline-track { position: absolute; left: 24px; right: 24px; top: 50%; height: 2px; background: #000; }

    .timeline-today { position: absolute; top: 50%; transform: translate(-50%, -50%); }
    .timeline-today__dot { width: 10px; height: 10px; border-radius: 50%; background: #000; display: block; }
    .timeline-today__label { position: absolute; top: 100%; left: 50%; transform: translateX(-50%); margin-top: 4px; font-size: 16px; font-weight: 700; white-space: nowrap; }

    .timeline-event { position: absolute; top: 50%; transform: translate(-50%, -50%); }
    .timeline-event__dot { width: 8px; height: 8px; border-radius: 50%; border: 2px solid #000; background: #fff; display: block; }
    .timeline-event__dot--once { border-radius: 0; }
    .timeline-event__label { position: absolute; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; line-height: 1.1; max-width: 110px; }
    .timeline-event__title { font-size: 15px; font-weight: 600; text-align: center; }
    .timeline-event__sub { font-size: 12px; }
    .timeline-event--up .timeline-event__label { bottom: 100%; margin-bottom: 6px; flex-direction: column-reverse; }
    .timeline-event--down .timeline-event__label { top: 100%; margin-top: 6px; }

    .aniv-timeline--compact .timeline-event__title { font-size: 12px; }
    .aniv-timeline--compact .timeline-event__sub { font-size: 10px; }
    .aniv-timeline--compact .timeline-event__label { max-width: 80px; }
    .aniv-timeline--narrow .timeline-event__label { max-width: 60px; }

    .timeline-empty { position: absolute; top: 50%; left: 50%; transform: translate(-50%, 32px); font-size: 14px; white-space: nowrap; }
    .aniv-timeline--compact .timeline-empty { font-size: 11px; }

    .month-tick { position: absolute; bottom: 6px; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; }
    .month-tick__line { width: 1px; height: 8px; background: #000; }
    .month-tick__label { font-size: 13px; margin-top: 2px; }

    .quad-list { display: flex; flex-direction: column; gap: 8px; width: 100%; padding: 0 18px; box-sizing: border-box; }
    .quad-list__item { display: flex; flex-direction: column; line-height: 1.2; }
    .quad-list__date { font-size: 14px; font-weight: 700; }
    .quad-list__days { font-size: 11px; }
    .quad-list__empty { font-size: 13px; text-align: center; width: 100%; }

    {% comment %}
      Positional utility classes, generated once here instead of using
      inline `style="left: N%"` on every dot/tick -- CHEF (TRMNL's plugin
      checker) flags inline styles even when they're per-render computed
      values, so dot/tick/today position is expressed as a class name
      (.pos-0 .. .pos-100) picked at render time instead.
    {% endcomment %}
    {% for i in (0..100) %}.pos-{{ i }} { left: {{ i }}%; }
    {% endfor %}
  </style>
{% endtemplate %}

{% template timeline_dot %}
  {% comment %} params: pct, label, sub, stagger, shape {% endcomment %}
  {% assign row_class = "timeline-event--down" %}
  {% if stagger == 1 %}
    {% assign row_class = "timeline-event--up" %}
  {% endif %}
  {% assign pos_class = "pos-" | append: pct %}
  <div class="timeline-event {{ row_class }} {{ pos_class }}">
    <div class="timeline-event__dot timeline-event__dot--{{ shape }}"></div>
    <div class="timeline-event__label">
      <span class="timeline-event__title">{{ label | truncate: 24 }}</span>
      {% if sub != blank %}<span class="timeline-event__sub">{{ sub }}</span>{% endif %}
    </div>
  </div>
{% endtemplate %}

{% template month_tick %}
  {% comment %} params: pct, text {% endcomment %}
  {% assign pos_class = "pos-" | append: pct %}
  <div class="month-tick {{ pos_class }}">
    <span class="month-tick__line"></span>
    <span class="month-tick__label">{{ text }}</span>
  </div>
{% endtemplate %}

{% template anniversary_screen %}
  {% comment %} params: special_dates, months_back, months_forward, mode {% endcomment %}

  {% capture nl %}
{% endcapture %}

  {% comment %} ---- "now", in the viewer's local time ---- {% endcomment %}
  {% assign utc_offset = trmnl.user.utc_offset | default: 0 %}
  {% assign utc_now_ts = "now" | date: "%s" | plus: 0 %}
  {% assign now_ts = utc_now_ts | plus: utc_offset %}
  {% assign today_weekday = now_ts | date: "%A" %}
  {% assign today_month_day = now_ts | date: "%B %-d" %}
  {% assign today_year_str = now_ts | date: "%Y" %}
  {% assign today_year = today_year_str | plus: 0 %}
  {% assign today_month0 = now_ts | date: "%-m" | minus: 1 %}

  {% comment %} ---- window bounds (approx. 30-day months) ---- {% endcomment %}
  {% assign back_months = months_back | default: 1 | plus: 0 %}
  {% assign fwd_months = months_forward | default: 4 | plus: 0 %}
  {% if back_months == 0 %}{% assign back_months = 1 %}{% endif %}
  {% if fwd_months == 0 %}{% assign fwd_months = 4 %}{% endif %}

  {% assign back_seconds = back_months | times: 30 | times: 86400 %}
  {% assign fwd_seconds = fwd_months | times: 30 | times: 86400 %}
  {% assign window_start_ts = now_ts | minus: back_seconds %}
  {% assign window_end_ts = now_ts | plus: fwd_seconds %}
  {% assign window_span = fwd_seconds | plus: back_seconds %}
  {% assign today_pct = back_seconds | times: 100.0 | divided_by: window_span | round %}

  {% comment %}
    ---- parse special_dates: render window dots, and separately track the
    two closest upcoming occurrences (next1/next2) regardless of whether
    they fall inside the graphical window. Two scalar "smallest so far"
    slots instead of a sortable array/JSON round-trip, since only the
    primitives already proven to work on-device are used here.
  {% endcomment %}
  {% assign lines = special_dates | split: nl %}
  {% assign dot_count = 0 %}
  {% assign next1_ts = -1 %}
  {% assign next2_ts = -1 %}
  {% capture dots_html %}
    {% for line in lines %}
      {% assign line = line | strip %}
      {% if line != blank %}
        {% assign parts = line | split: "|" %}
        {% if parts.size >= 3 %}
          {% assign raw_date = parts[0] | strip %}
          {% assign ev_label = parts[1] | strip %}
          {% assign recur = parts[2] | strip | downcase %}
          {% assign date_parts = raw_date | split: "-" %}

          {% if recur == "once" %}
            {% if date_parts.size == 3 %}
              {% assign ev_ts = raw_date | date: "%s" | plus: 0 %}
              {% assign ev_date_label = raw_date | date: "%b %-d" %}
              {% if ev_ts >= now_ts %}
                {% if next1_ts == -1 or ev_ts < next1_ts %}
                  {% assign next2_ts = next1_ts %}
                  {% assign next2_label = next1_label %}
                  {% assign next2_sub = next1_sub %}
                  {% assign next2_date_label = next1_date_label %}
                  {% assign next1_ts = ev_ts %}
                  {% assign next1_label = ev_label %}
                  {% assign next1_sub = "" %}
                  {% assign next1_date_label = ev_date_label %}
                {% elsif next2_ts == -1 or ev_ts < next2_ts %}
                  {% assign next2_ts = ev_ts %}
                  {% assign next2_label = ev_label %}
                  {% assign next2_sub = "" %}
                  {% assign next2_date_label = ev_date_label %}
                {% endif %}
              {% endif %}
              {% if ev_ts >= window_start_ts and ev_ts <= window_end_ts %}
                {% assign pct = ev_ts | minus: window_start_ts | times: 100.0 | divided_by: window_span | round %}
                {% assign stagger = dot_count | modulo: 2 %}
                {% render "timeline_dot", pct: pct, label: ev_label, sub: "", stagger: stagger, shape: "once" %}
                {% assign dot_count = dot_count | plus: 1 %}
              {% endif %}
            {% endif %}
          {% else %}
            {% assign start_year = "" %}
            {% if date_parts.size == 3 %}
              {% assign start_year = date_parts[0] %}
              {% assign ev_month = date_parts[1] %}
              {% assign ev_day = date_parts[2] %}
            {% elsif date_parts.size == 2 %}
              {% assign ev_month = date_parts[0] %}
              {% assign ev_day = date_parts[1] %}
            {% endif %}
            {% if ev_month and ev_day %}
              {% assign yoffset_start = 0 | minus: 1 %}
              {% for yoffset in (yoffset_start..1) %}
                {% assign cand_year = today_year | plus: yoffset %}
                {% assign cand_date = cand_year | append: "-" | append: ev_month | append: "-" | append: ev_day %}
                {% assign cand_ts = cand_date | date: "%s" | plus: 0 %}
                {% assign cand_date_label = cand_date | date: "%b %-d" %}
                {% assign sub = "" %}
                {% if start_year != "" %}
                  {% assign age = cand_year | minus: start_year %}
                  {% if age >= 0 %}
                    {% assign sub = age | append: " yrs" %}
                  {% endif %}
                {% endif %}
                {% if cand_ts >= now_ts %}
                  {% if next1_ts == -1 or cand_ts < next1_ts %}
                    {% assign next2_ts = next1_ts %}
                    {% assign next2_label = next1_label %}
                    {% assign next2_sub = next1_sub %}
                    {% assign next2_date_label = next1_date_label %}
                    {% assign next1_ts = cand_ts %}
                    {% assign next1_label = ev_label %}
                    {% assign next1_sub = sub %}
                    {% assign next1_date_label = cand_date_label %}
                  {% elsif next2_ts == -1 or cand_ts < next2_ts %}
                    {% assign next2_ts = cand_ts %}
                    {% assign next2_label = ev_label %}
                    {% assign next2_sub = sub %}
                    {% assign next2_date_label = cand_date_label %}
                  {% endif %}
                {% endif %}
                {% if cand_ts >= window_start_ts and cand_ts <= window_end_ts %}
                  {% assign pct = cand_ts | minus: window_start_ts | times: 100.0 | divided_by: window_span | round %}
                  {% assign stagger = dot_count | modulo: 2 %}
                  {% render "timeline_dot", pct: pct, label: ev_label, sub: sub, stagger: stagger, shape: "yearly" %}
                  {% assign dot_count = dot_count | plus: 1 %}
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endcapture %}

  {% assign days_until = 0 %}
  {% if next1_ts != -1 %}
    {% assign secs_until = next1_ts | minus: now_ts %}
    {% assign days_until = secs_until | plus: 43200 | divided_by: 86400 %}
  {% endif %}

  {% comment %} ---- month ruler (skipped in compact modes) ---- {% endcomment %}
  {% capture ticks_html %}
    {% unless compact %}
      {% assign tick_start = 0 | minus: back_months %}
      {% for i in (tick_start..fwd_months) %}
        {% assign tick_month0 = today_month0 | plus: i %}
        {% assign year_delta = tick_month0 | divided_by: 12 %}
        {% assign tick_year = today_year | plus: year_delta %}
        {% assign tick_month0_norm = tick_month0 | modulo: 12 %}
        {% assign tick_month1 = tick_month0_norm | plus: 1 %}
        {% assign tick_date = tick_year | append: "-" | append: tick_month1 | append: "-01" %}
        {% assign tick_ts = tick_date | date: "%s" | plus: 0 %}
        {% if tick_ts >= window_start_ts and tick_ts <= window_end_ts %}
          {% assign pct = tick_ts | minus: window_start_ts | times: 100.0 | divided_by: window_span | round %}
          {% assign tick_label = tick_date | date: "%b" %}
          {% render "month_tick", pct: pct, text: tick_label %}
        {% endif %}
      {% endfor %}
    {% endunless %}
  {% endcapture %}

  {% comment %} ---- assemble output for the requested layout ---- {% endcomment %}
  {% case mode %}
  {% when "full" %}
    <div class="aniv-half aniv-half--r55">
      <div class="aniv-date">
        <span class="aniv-date__weekday">{{ today_weekday }}</span>
        <span class="aniv-date__big">{{ today_month_day }}</span>
        <span class="aniv-date__year">{{ today_year }}</span>
        {% if next1_ts != -1 %}
          <span class="aniv-date__next">Next: {{ next1_label | truncate: 30 }} in {{ days_until }} day{% if days_until != 1 %}s{% endif %}</span>
        {% endif %}
      </div>
    </div>
    <div class="aniv-half aniv-half--r45">
      <div class="aniv-timeline aniv-timeline--full">
        <div class="timeline-track"></div>
        <div class="timeline-today pos-{{ today_pct }}">
          <span class="timeline-today__dot"></span>
          <span class="timeline-today__label">Today</span>
        </div>
        {{ ticks_html }}
        {{ dots_html }}
        {% if dot_count == 0 %}<div class="timeline-empty">No dates in range</div>{% endif %}
      </div>
    </div>
  {% when "half_horizontal" %}
    <div class="aniv-half aniv-half--r40">
      <div class="aniv-date aniv-date--row">
        <span class="aniv-date__big aniv-date__big--sm">{{ today_month_day }}</span>
        <span class="aniv-date__weekday">{{ today_weekday }}, {{ today_year }}</span>
      </div>
    </div>
    <div class="aniv-half aniv-half--r60">
      <div class="aniv-timeline aniv-timeline--compact">
        <div class="timeline-track"></div>
        <div class="timeline-today pos-{{ today_pct }}">
          <span class="timeline-today__dot"></span>
        </div>
        {{ dots_html }}
        {% if dot_count == 0 %}<div class="timeline-empty">No dates in range</div>{% endif %}
      </div>
    </div>
  {% when "half_vertical" %}
    <div class="aniv-half aniv-half--r50">
      <div class="aniv-date">
        <span class="aniv-date__weekday">{{ today_weekday }}</span>
        <span class="aniv-date__big aniv-date__big--sm">{{ today_month_day }}</span>
        <span class="aniv-date__year">{{ today_year }}</span>
      </div>
    </div>
    <div class="aniv-half aniv-half--r50">
      <div class="aniv-timeline aniv-timeline--compact aniv-timeline--narrow">
        <div class="timeline-track"></div>
        <div class="timeline-today pos-{{ today_pct }}">
          <span class="timeline-today__dot"></span>
        </div>
        {{ dots_html }}
        {% if dot_count == 0 %}<div class="timeline-empty">No dates in range</div>{% endif %}
      </div>
    </div>
  {% when "quadrant" %}
    <div class="aniv-half aniv-half--r40">
      <div class="aniv-date aniv-date--quad">
        <span class="aniv-date__big aniv-date__big--xs">{{ today_month_day }}</span>
        <span class="aniv-date__weekday">{{ today_weekday }}</span>
      </div>
    </div>
    <div class="aniv-half aniv-half--r60 aniv-half--start">
      <div class="quad-list">
        {% if next1_ts == -1 %}
          <div class="quad-list__empty">No upcoming dates</div>
        {% else %}
          <div class="quad-list__item">
            <span class="quad-list__date">{{ next1_date_label }} &mdash; {{ next1_label | truncate: 20 }}</span>
            <span class="quad-list__days">in {{ days_until }}d{% if next1_sub != blank %} &middot; {{ next1_sub }}{% endif %}</span>
          </div>
          {% if next2_ts != -1 %}
            <div class="quad-list__item">
              <span class="quad-list__date">{{ next2_date_label }} &mdash; {{ next2_label | truncate: 20 }}</span>
              {% if next2_sub != blank %}<span class="quad-list__days">{{ next2_sub }}</span>{% endif %}
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
  {% endcase %}
{% endtemplate %}
